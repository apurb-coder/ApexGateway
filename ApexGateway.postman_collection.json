        {
          "name": "Proxy Request",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/:apiName/v1/forecast?latitude=52.52&longitude=13.41&current_weather=true",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "api",
                ":apiName",
                "v1",
                "forecast"
              ],
              "query": [
                {
                  "key": "latitude",
                  "value": "52.52"
                },
                {
                  "key": "longitude",
                  "value": "52.52"
                },
                {
                  "key": "current_weather",
                  "value": "true"
                }
              ],
              "variable": [
                {
                  "key": "apiName",
                  "value": "weather-service",
                  "description": "Registered API name/slug on the gateway"
                }
              ]
            }
          },
          "response": []
        }
