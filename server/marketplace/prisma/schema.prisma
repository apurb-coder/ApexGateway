datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PROVIDER
  CONSUMER
  ADMIN
}

enum ApiStatus {
  ACTIVE
  INACTIVE
  DEGRADED
}

model User {
  id           String              @id @default(uuid())
  email        String              @unique
  passwordHash String
  role         Role                @default(CONSUMER)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  apis         Api[]
  subscriptions Subscription[]
  
  // New relations for tracking finances
  earnings     Transaction[]       @relation("ProviderEarnings")
  withdrawals  WithdrawalRequest[] @relation("ProviderWithdrawals")
}

model Api {
  id             String        @id @default(uuid())
  name           String
  description    String?
  upstreamUrl    String
  allowedMethods String[]
  exampleDocs    String?
  status         ApiStatus     @default(ACTIVE)
  providerId     String
  provider       User          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  plans          Plan[]
  healthChecks   HealthCheck[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Plan {
  id             String         @id @default(uuid())
  apiId          String
  api            Api            @relation(fields: [apiId], references: [id], onDelete: Cascade)
  name           String
  requestsPerMin Int
  price          Decimal        @db.Decimal(10, 2)
  subscriptions  Subscription[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Subscription {
  id          String        @id @default(uuid())
  consumerId  String
  consumer    User          @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  planId      String
  plan        Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  apiKeyHash  String        @unique
  
  // Change default to false: subscriptions are inactive until paid
  isActive    Boolean       @default(false)
  
  // Stripe Checkout Session correlation
  stripeSessionId   String?   @unique
  stripeCheckoutUrl String?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  transactions Transaction[]
}

model HealthCheck {
  id         String   @id @default(uuid())
  apiId      String
  api        Api      @relation(fields: [apiId], references: [id], onDelete: Cascade)
  statusCode Int
  latencyMs  Int
  timestamp  DateTime @default(now())

  @@index([apiId, timestamp])
}

model ApiLog {
  id             String   @id @default(uuid())
  apiId          String?
  apiName        String?
  subscriptionId String?
  path           String
  method         String
  statusCode     Int
  latencyMs      Int
  timestamp      DateTime @default(now())

  @@map("api_logs")
}

model Transaction {
  id              String       @id @default(uuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  providerId      String
  provider        User         @relation("ProviderEarnings", fields: [providerId], references: [id], onDelete: Cascade)
  amount          Decimal      @db.Decimal(10, 2) // Price paid
  currency        String       @default("USD")
  stripePaymentId String?      @unique            // PaymentIntent ID
  createdAt       DateTime     @default(now())
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model WithdrawalRequest {
  id             String           @id @default(uuid())
  providerId     String
  provider       User             @relation("ProviderWithdrawals", fields: [providerId], references: [id], onDelete: Cascade)
  amount         Decimal          @db.Decimal(10, 2)
  status         WithdrawalStatus @default(PENDING)
  payoutMethod   String           // "BANK_TRANSFER", "PAYPAL", "STRIPE_DIRECT"
  payoutDetails  Json             // { bankName, accountNumber, routingNumber } or { paypalEmail }
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  processedAt    DateTime?
}
